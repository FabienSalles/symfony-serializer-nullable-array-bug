{
    "name": "fabiensalles/symfony-serializer-nullable-array-bug",
    "description": "Bug reproducer: AbstractObjectNormalizer loses collection type info for nullable array constructor params",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "symfony/serializer": "^7.3",
        "symfony/property-info": "^7.3",
        "symfony/property-access": "^7.3",
        "phpdocumentor/reflection-docblock": "^5.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    }
}
